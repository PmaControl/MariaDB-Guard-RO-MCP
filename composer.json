{
    "name": "pmacontrol/mariadb-guard-ro-mcp",
    "description": "Read-only MCP server for MariaDB/MySQL with SQL guardrails, execution limits and explain diagnostics.",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "mcp",
        "mariadb",
        "mysql",
        "security",
        "read-only"
    ],
    "homepage": "https://github.com/PmaControl/MariaDB-Guard-RO-MCP",
    "support": {
        "source": "https://github.com/PmaControl/MariaDB-Guard-RO-MCP",
        "issues": "https://github.com/PmaControl/MariaDB-Guard-RO-MCP/issues"
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "classmap": [
            "src/"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test:verbose": "phpunit --configuration phpunit.xml --testdox"
    }
}
