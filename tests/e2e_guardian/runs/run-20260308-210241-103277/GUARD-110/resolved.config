TEST_ID=GUARD-110
TEST_NAME=Checklist sécurité compte DB
TEST_DESCRIPTION=mcp_test doit être safe=true avec compte read-only
BLOCK=security
TAGS=security,full
PRIORITY=P1
TIMEOUT_S=20
RETRIES=0
DB_ENGINE=mariadb
DB_VERSION=11.8
SSL_MODE=off
GUARDIAN=sql-guard
STACK=apache-php
PR_ID=none
MCP_ID=mcp-core
MCP_ENDPOINT=http://127.0.0.1:49999/mcp
MCP_TOKEN=***
PRE_HOOK=
POST_HOOK=
COMMAND=curl -sS -m 12 -X POST "$MCP_ENDPOINT" -H "content-type: application/json" -H "authorization: Bearer $MCP_TOKEN" --data "{\"jsonrpc\":\"2.0\",\"id\":4,\"method\":\"tools/call\",\"params\":{\"name\":\"mcp_test\",\"arguments\":{\"forceRefresh\":true}}}" | jq -e ".result.structuredContent.safe == true" >/dev/null
EXPECT_JSON_PATH=
EXPECT_EQUALS=
ENABLED=true
MATRIX_EXPAND=false
DB_VERSION_LIST=11.8
SSL_MODE_LIST=off
