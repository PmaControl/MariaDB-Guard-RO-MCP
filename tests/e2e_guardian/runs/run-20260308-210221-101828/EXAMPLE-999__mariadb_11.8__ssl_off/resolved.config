TEST_ID=EXAMPLE-999
TEST_NAME=Exemple complet .test
TEST_DESCRIPTION=Template complet avec mapping id -> PR -> MCP et paramètres SSL
BLOCK=example
TAGS=example,template
PRIORITY=P1
TIMEOUT_S=30
RETRIES=1
DB_ENGINE=mariadb
DB_VERSION=11.8
SSL_MODE=off
GUARDIAN=sql-guard
STACK=apache-php
PR_ID=7013
MCP_ID=mcp-7012
MCP_ENDPOINT=http://127.0.0.1:49999/mcp
MCP_TOKEN=***
PRE_HOOK=echo "prepare test context"
POST_HOOK=echo "cleanup test context"
COMMAND=curl -sS -m 10 -X POST "$MCP_ENDPOINT" \
  -H "content-type: application/json" \
  -H "authorization: Bearer $MCP_TOKEN" \
  --data "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{}}"
EXPECT_JSON_PATH=.result.protocolVersion
EXPECT_EQUALS=2024-11-05
ENABLED=true
MATRIX_EXPAND=true
DB_VERSION_LIST=10.11,11.4,11.8
SSL_MODE_LIST=off,files,server
