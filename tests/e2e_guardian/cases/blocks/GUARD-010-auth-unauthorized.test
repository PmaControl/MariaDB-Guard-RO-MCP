TEST_ID="GUARD-010"
TEST_NAME="Initialize refusé sans token"
TEST_DESCRIPTION="Doit renvoyer -32001 Unauthorized"
BLOCK="auth"
TAGS="auth,negative,smoke"
PRIORITY="P0"
TIMEOUT_S=10
RETRIES=0

DB_ENGINE="mariadb"
DB_VERSION="11.8"
SSL_MODE="off"
GUARDIAN="sql-guard"
STACK="apache-php"

PR_ID="none"
MCP_ID="mcp-core"
MCP_ENDPOINT="${MCP_ENDPOINT:-http://127.0.0.1:49999/mcp}"
MCP_TOKEN="${MCP_TOKEN:-my_token}"

COMMAND='curl -sS -m 8 -X POST "$MCP_ENDPOINT" -H "content-type: application/json" --data "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{}}" | jq -e ".error.code == -32001" >/dev/null'
