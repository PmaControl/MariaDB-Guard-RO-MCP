TEST_ID="GUARD-900"
TEST_NAME="Matrice SSL multi-version"
TEST_DESCRIPTION="Valide la négociation SSL selon mode off/files/server"
BLOCK="ssl-matrix"
TAGS="hardcore,ssl,matrix"
PRIORITY="P2"
TIMEOUT_S=20
RETRIES=0

DB_ENGINE="mariadb"
DB_VERSION="11.8"
SSL_MODE="off"
GUARDIAN="ssl-guardian"
STACK="apache-php"

PR_ID="7012"
MCP_ID="mcp-ssl"
MCP_ENDPOINT="${MCP_ENDPOINT:-http://127.0.0.1:49999/mcp}"
MCP_TOKEN="${MCP_TOKEN:-my_token}"

MATRIX_EXPAND=true
DB_VERSION_LIST="10.11,11.4,11.8"
SSL_MODE_LIST="off,files,server"

COMMAND='resp=$(curl -sS -m 12 -X POST "$MCP_ENDPOINT" -H "content-type: application/json" -H "authorization: Bearer $MCP_TOKEN" --data "{\"jsonrpc\":\"2.0\",\"id\":5,\"method\":\"tools/call\",\"params\":{\"name\":\"db_select\",\"arguments\":{\"sql\":\"SHOW STATUS LIKE \\\"Ssl_cipher\\\"\"}}}"); echo "$resp" | jq -e ".result.structuredContent.rows | length >= 1" >/dev/null'
